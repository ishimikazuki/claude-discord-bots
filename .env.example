# Copy to .env and fill with your actual Discord bot tokens.
# Alternatively, store tokens in macOS keychain:
#   security add-generic-password -a "<account>" -s "discord-bot" -w "<token>"
# When both are present, .env takes precedence.

general-bot-token=YOUR_DISCORD_BOT_TOKEN_HERE
project-a-bot-token=YOUR_DISCORD_BOT_TOKEN_HERE
